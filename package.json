{
  "name": "@winm2m/react-data-workspace",
  "version": "0.4.4",
  "description": "Composable data workspace shell that embeds @winm2m/react-stats-ui plugins",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dist/index.css": {
      "default": "./dist/index.css"
    },
    "./dist/index.css.map": {
      "default": "./dist/index.css.map"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:jest && npm run test:vitest",
    "test:jest": "jest",
    "test:vitest": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WinM2M/react-data-workspace.git"
  },
  "keywords": [
    "react",
    "workspace",
    "statistics"
  ],
  "author": "WINM2M",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/WinM2M/react-data-workspace/issues"
  },
  "homepage": "https://github.com/WinM2M/react-data-workspace#readme",
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@winm2m/react-stats-ui": "^0.8.1",
    "i18next": "^26.0.3",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.2",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.18",
    "@storybook/addon-interactions": "^8.6.18",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/blocks": "^8.6.18",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@storybook/test": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.9",
    "storybook": "^8.6.18",
    "tailwindcss": "^3.4.15",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.3"
  }
}
